                  },
                  "preset": {
                    "type": "string",
                    "description": "Preset profile name, must match uploaded profile (optional for 3mf, default: profile from 3mf)"
                  },
                  "filament": {
                    "type": "string",
                    "description": "Filament profile name, must match uploaded profile (optional for 3mf, default: profile from 3mf)"
                  },
                  "bedType": {
                    "type": "string",
                    "description": "Bed type as named inside the profile (optional, default: Textured PEI Plate)"
                  },
                  "plate": {
                    "type": "string",
                    "description": "Plate number to slice (optional, default: 1, 0 for all plates)"
                  },
                  "arrange": {
                    "type": "boolean",
                    "description": "Auto-arrange models on the plate (optional, default: false)"
                  },
                  "orient": {
                    "type": "boolean",
                    "description": "Auto-orient models (optional, default: false)"
                  },
                  "exportType": {
                    "type": "string",
                    "enum": [
                      "gcode",
