{
  "openapi": "3.0.3",
  "info": {
    "title": "OrcaSlicer API",
    "version": "1.1.0",
    "description": "REST API for slicing 3D models (STL, OBJ, AMF, 3MF and STEP/IGES/BREP CAD files) with OrcaSlicer. Manage profiles, inspect geometry, convert models and read print statistics. The same engine is exposed as the 'osa' terminal CLI \u2014 see CLI.md."
  },
  "servers": [
    {
      "url": "http://localhost:3000"
    }
  ],
  "tags": [
    {
      "name": "Slicing",
      "description": "Synchronous endpoints for slicing 3D models (blocks until complete)"
    },
    {
      "name": "Async Slicing",
      "description": "Asynchronous endpoints for slicing 3D models (fire and forget with polling)"
    },
    {
      "name": "Profiles",
      "description": "Endpoints for managing printer, preset, and filament profiles"
    },
    {
      "name": "Tools",
      "description": "Model inspection, conversion and G-code analysis"
    },
    {
      "name": "Presets",
      "description": "Browse OrcaSlicer's bundled system presets"
    },
    {
      "name": "Health",
      "description": "Service and environment health"
    }
  ],
  "paths": {
    "/slice": {
      "post": {
        "tags": [
          "Slicing"
        ],
        "summary": "Slice a 3D model file",
        "description": "Uploads a 3D model (STL, STEP, or 3MF) and returns a G-code or 3MF file. If multiple G-codes are generated (multi-plate), a ZIP archive is returned.",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "file"
                ],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "STL, STEP, or 3MF model file"
                  },
                  "printerProfile": {
                    "type": "string",
                    "format": "binary",
                    "description": "Printer profile JSON file, prioritized over printer field, will not be saved to disk (optional, default: profile from 3mf or uploaded profile set in printer field)"
                  },
                  "presetProfile": {
                    "type": "string",
                    "format": "binary",
                    "description": "Preset profile JSON file, prioritized over preset field, will not be saved to disk (optional, default: profile from 3mf or uploaded profile set in preset field)"
                  },
                  "filamentProfile": {
                    "type": "string",
                    "format": "binary",
                    "description": "Filament profile JSON file, prioritized over filament field, will not be saved to disk (optional, default: profile from 3mf or uploaded profile set in filament field)"
                  },
                  "printer": {
                    "type": "string",
                    "description": "Printer profile name, must match uploaded profile (optional for 3mf, default: profile from 3mf)"
                  },
                  "preset": {
                    "type": "string",
                    "description": "Preset profile name, must match uploaded profile (optional for 3mf, default: profile from 3mf)"
                  },
                  "filament": {
                    "type": "string",
                    "description": "Filament profile name, must match uploaded profile (optional for 3mf, default: profile from 3mf)"
                  },
                  "bedType": {
                    "type": "string",
                    "description": "Bed type as named inside the profile (optional, default: Textured PEI Plate)"
                  },
                  "plate": {
                    "type": "string",
                    "description": "Plate number to slice (optional, default: 1, 0 for all plates)"
                  },
                  "arrange": {
                    "type": "boolean",
                    "description": "Auto-arrange models on the plate (optional, default: false)"
                  },
                  "orient": {
                    "type": "boolean",
                    "description": "Auto-orient models (optional, default: false)"
                  },
                  "exportType": {
                    "type": "string",
                    "enum": [
                      "gcode",
                      "3mf"
                    ],
                    "description": "Export gcode or 3mf (optional, default: gcode)"
                  },
                  "multicolorOnePlate": {
                    "type": "boolean",
                    "description": "Allow multicolor on one plate when using arrange (optional, default: false)"
                  },
                  "rotate": {
                    "type": "string",
                    "description": "Rotation around Z in degrees"
                  },
                  "rotateX": {
                    "type": "string",
                    "description": "Rotation around X in degrees"
                  },
                  "rotateY": {
                    "type": "string",
                    "description": "Rotation around Y in degrees"
                  },
                  "scale": {
                    "type": "string",
                    "description": "Uniform scale factor"
                  },
                  "repetitions": {
                    "type": "string",
                    "description": "Repeat the whole model N times"
                  },
                  "ensureOnBed": {
                    "type": "boolean",
                    "description": "Lift objects partially below the bed"
                  },
                  "assemble": {
                    "type": "boolean",
                    "description": "Merge all loaded models into one object"
                  },
                  "convertUnit": {
                    "type": "boolean",
                    "description": "Convert model units (inch to mm)"
                  },
                  "allowRotations": {
                    "type": "boolean",
                    "description": "Allow rotation while arranging"
                  },
                  "skipObjects": {
                    "type": "string",
                    "description": "Comma-separated 1-based object indices to skip"
                  },
                  "cloneObjects": {
                    "type": "string",
                    "description": "Comma-separated object clone pairs, e.g. 1,3"
                  },
                  "layerHeight": {
                    "type": "string",
                    "description": "Layer height override in mm (0.04-0.6)"
                  },
                  "infillDensity": {
                    "type": "string",
                    "description": "Sparse infill density override, 0-100 percent"
                  },
                  "infillPattern": {
                    "type": "string",
                    "description": "Sparse infill pattern, e.g. grid, gyroid"
                  },
                  "wallCount": {
                    "type": "string",
                    "description": "Wall loop count override (1-10)"
                  },
                  "nozzleDiameter": {
                    "type": "string",
                    "description": "Nozzle diameter override in mm (0.1-2.0)"
                  },
                  "printSpeed": {
                    "type": "string",
                    "enum": [
                      "standard",
                      "safe",
                      "slow"
                    ],
                    "description": "Coarse print-speed bucket"
                  },
                  "support": {
                    "type": "string",
                    "enum": [
                      "auto",
                      "tree",
                      "tree-auto",
                      "none"
                    ],
                    "description": "Support generation mode"
                  },
                  "supportThreshold": {
                    "type": "string",
                    "description": "Support overhang angle threshold in degrees"
                  },
                  "brimType": {
                    "type": "string",
                    "description": "Brim type, e.g. outer_only, no_brim"
                  },
                  "brimWidth": {
                    "type": "string",
                    "description": "Brim width in mm"
                  },
                  "timelapse": {
                    "type": "boolean",
                    "description": "Slice as a timelapse print"
                  },
                  "debugLevel": {
                    "type": "string",
                    "description": "OrcaSlicer log verbosity, 0-5"
                  },
                  "set": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Raw OrcaSlicer config overrides as key=value strings (highest priority)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "G-code or 3MF file generated. If multiple G-codes, a ZIP archive is returned.",
            "headers": {
              "X-Print-Time-Seconds": {
                "description": "Estimated total print time in seconds",
                "schema": {
                  "type": "string"
                }
              },
              "X-Filament-Used-g": {
                "description": "Filament used in grams",
                "schema": {
                  "type": "string"
                }
              },
              "X-Filament-Used-mm": {
                "description": "Filament used in millimeters",
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                },
                "examples": {
                  "gcodeFile": {
                    "summary": "Example G-code file",
                    "description": "A sample G-code file generated by the slicer.",
                    "value": "G28 ; Home all axes\n..."
                  },
                  "3mfFile": {
                    "summary": "Example 3MF file",
                    "description": "A sample 3MF file generated by the slicer, includes gcodes for printing.",
                    "value": "<3mf data>"
                  },
                  "zipFile": {
                    "summary": "Example ZIP file",
                    "description": "A ZIP archive containing multiple G-code files.",
                    "value": "<binary zip data>"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid input or missing parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Slicing failed or server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/slice-async": {
