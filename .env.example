# OrcaSlicer API / CLI configuration. Copy to .env and edit.

# Path to the OrcaSlicer binary or launcher script (required).
# Produced by ./scripts/provision-orcaslicer.sh — usually .orca-runtime/orca
ORCASLICER_PATH=/path/to/.orca-runtime/orca

# Profile storage directory (printers/ presets/ filaments/). Default: ./data
DATA_PATH=./data

# OrcaSlicer "resources" directory — enables the `presets` command / endpoints.
# Optional; derived from ORCASLICER_PATH when that points at the real binary.
ORCA_RESOURCES_PATH=/path/to/.orca-runtime/squashfs-root/resources

# HTTP server port for `osa serve` / `npm start`. Default: 3000
PORT=3000

# development | production
NODE_ENV=development
